#!/usr/bin/env fish
# share-usage.fish
#
# Summarizes ~/.claude/usage.jsonl per-skill counts.
# No timestamps, no sessions, no skill-argument content in output.
#
# Usage:
#   fish bin/share-usage.fish          # print summary to stdout
#   fish bin/share-usage.fish --gh     # print the gh issue create command to run

set -l usage_log (set -q USAGE_LOG; and echo $USAGE_LOG; or echo "$HOME/.claude/usage.jsonl")
set -l mode "print"

if test (count $argv) -gt 0
    switch $argv[1]
        case --gh
            set mode "gh"
        case '*'
            echo "Unknown flag: $argv[1]" >&2
            echo "Usage: fish bin/share-usage.fish [--gh]" >&2
            exit 2
    end
end

if not test -f "$usage_log"
    echo "No usage log found at $usage_log" >&2
    echo "Install the hook with: fish bin/install-usage-hook.fish" >&2
    exit 1
end

set -l total_count (jq -s 'length' "$usage_log" 2>/dev/null)
if test -z "$total_count"; or test "$total_count" -eq 0
    echo "No leadership-toolkit invocations recorded yet." >&2
    exit 0
end

# per-skill counts: one "skill count" pair per line, sorted by count desc
# No timestamps or session IDs — counts only per ADR #0021 privacy posture.
set -l count_lines (jq -r '.skill' "$usage_log" 2>/dev/null | sort | uniq -c | sort -rn | awk '{print $2, $1}')

switch $mode
    case print
        echo "Leadership-toolkit usage summary"
        echo "================================"
        echo ""
        for line in $count_lines
            set -l parts (string split " " $line)
            echo "  $parts[1]: $parts[2]"
        end
        echo ""
        echo "Total invocations: $total_count"

    case gh
        # Write body to a temp file and print a gh command that uses --body-file.
        # This avoids shell quoting complexity with multi-line bodies.
        set -l body_file (mktemp /tmp/usage-share-body.XXXXXX)
        echo "Leadership-toolkit usage summary (per-skill counts only):" >> "$body_file"
        echo "" >> "$body_file"
        for line in $count_lines
            set -l parts (string split " " $line)
            echo "- $parts[1]: $parts[2]" >> "$body_file"
        end
        echo "" >> "$body_file"
        echo "Total invocations: $total_count" >> "$body_file"
        echo "" >> "$body_file"
        echo "Generated by fish bin/share-usage.fish --gh. No timestamps or sessions included." >> "$body_file"
        echo "Run this command to open a pre-filled issue:"
        echo ""
        echo "gh issue create --title 'Usage telemetry: leadership-toolkit engagement' --body-file $body_file"
        echo ""
        echo "(Body file: $body_file — delete after use)"
end
