#!/usr/bin/env fish
# Regenerate tests/anchor-snapshots.txt from the current rules/ tree.
#
# Reads the anchor registry from validate.fish Phase 1j (single source of
# truth for which anchors are tracked). For each (anchor, canonical-file)
# pair, computes the section-body sha256 using the same algorithm as
# validate.fish Phase 1v + tests/validate-phase-1v.test.ts and writes a
# pipe-delimited `anchor|basename|hash` row to tests/anchor-snapshots.txt.
#
# Run after editing any anchor section body. Commit the regenerated
# snapshot in the same PR as the prose change so CI passes.

set -l repo_dir (cd (dirname (status filename)); and cd ..; and pwd)
set -l snapshot "$repo_dir/tests/anchor-snapshots.txt"

# Mirror the Phase 1j anchor registry. Keep in sync — adding an entry here
# without also adding it to Phase 1j's registry means the snapshot tracks an
# anchor whose ID itself is not guarded, defeating the purpose.
set -l registry \
    "trivial-tier-criteria|planning-pipeline.md" \
    "skip-contract|skip-contract.md" \
    "emission-contract|skip-contract.md" \
    "pressure-framing-floor|pressure-framing-floor.md" \
    "architectural-invariant|pressure-framing-floor.md" \
    "emergency-bypass-sentinel|pressure-framing-floor.md" \
    "fast-track-validation-emission|pressure-framing-floor.md" \
    "single-implementer-mode|execution-mode.md" \
    "verify-checks|goal-driven.md" \
    "scope-tier-memory-check|pressure-framing-floor.md" \
    "goal-verification|verification.md" \
    "hard-gate-cap|GOVERNANCE.md" \
    "override-skip-contract|skip-contract.md" \
    "emission-contract-per-gate|skip-contract.md"

function hash_body --argument-names file aid
    set -l start_line (grep -nF "<a id=\"$aid\"></a>" $file 2>/dev/null | head -1 | cut -d: -f1)
    if test -z "$start_line"
        echo "NO_ANCHOR"
        return 1
    end
    set -l body_start (math $start_line + 1)
    set -l body (awk -v s=$body_start '
        NR < s { next }
        !seen_first {
            if ($0 == "") next
            seen_first=1; print; next
        }
        /^<a id=/ { exit }
        /^## / { exit }
        { print }
    ' $file)
    set -l normalized (printf '%s\n' $body | sed 's/[[:space:]]*$//' | awk 'NF{p=1} p{a[++n]=$0} END{while(n>0 && a[n]==""){n--} for(i=1;i<=n;i++)print a[i]}')
    printf '%s\n' $normalized | shasum -a 256 | cut -d' ' -f1
end

set -l tmpfile (mktemp)
echo "# Anchor body snapshot — regenerated by bin/regen-anchor-snapshots.fish" > $tmpfile
echo "# Format: <anchor>|<basename>|<sha256>" >> $tmpfile
for entry in $registry
    set -l parts (string split -m 1 "|" $entry)
    set -l aid $parts[1]
    set -l basename $parts[2]
    set -l file "$repo_dir/rules/$basename"
    if not test -f $file
        echo "ERROR: rules/$basename missing" >&2
        rm -f $tmpfile
        exit 1
    end
    set -l hash (hash_body $file $aid)
    if test "$hash" = "NO_ANCHOR"
        echo "ERROR: anchor #$aid not present in rules/$basename" >&2
        rm -f $tmpfile
        exit 1
    end
    echo "$aid|$basename|$hash" >> $tmpfile
end
mv $tmpfile $snapshot
echo "Wrote "(grep -cv '^#' $snapshot)" entries to tests/anchor-snapshots.txt"
